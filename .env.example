# Codex Dashboard 환경 설정
# 이 파일을 .env로 복사 후 값을 수정하세요: cp .env.example .env

# 로그인 비밀번호 (설정 시 로그인 필수)
DASHBOARD_PASSWORD=codex2026

# 세션 서명 시크릿 (설정하지 않으면 서버 시작 시 자동 생성 — 재시작 시 세션 무효화)
# DASHBOARD_SECRET=

# HTTPS 배포 시 true
# DASHBOARD_SECURE=false

# 허용 오리진 (쉼표 구분)
# DASHBOARD_CORS_ORIGINS=

# 서버 포트 (기본: 8617)
# PORT=8617
