{
  "annotations": { "list": [] },
  "description": "Claude Usage Dashboard — minimal 4-panel health view. Import via Grafana UI: Dashboards → New → Import → Upload JSON. Pick the Prometheus datasource that scrapes the dashboard's /metrics endpoint.",
  "editable": true,
  "schemaVersion": 38,
  "title": "Claude Dashboard — health",
  "uid": "claude-dashboard-health",
  "tags": ["claude", "dashboard"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service up",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"claude-dashboard\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "WS clients",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "dashboard_ws_connections", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Sessions",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "dashboard_sessions_total", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Messages",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "dashboard_messages_total", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP request rate (by status)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        { "expr": "sum by (status) (rate(http_requests_total{job=\"claude-dashboard\"}[1m]))", "refId": "A", "legendFormat": "{{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP latency p50 / p95 / p99",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"claude-dashboard\"}[5m])) by (le))", "refId": "A", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"claude-dashboard\"}[5m])) by (le))", "refId": "B", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"claude-dashboard\"}[5m])) by (le))", "refId": "C", "legendFormat": "p99" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Ingest rate (new messages / minute)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 13 },
      "targets": [
        { "expr": "rate(dashboard_new_messages_total[1m]) * 60", "refId": "A", "legendFormat": "msgs/min" }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "DB size (bytes)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 13 },
      "targets": [
        { "expr": "dashboard_db_size_bytes", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
